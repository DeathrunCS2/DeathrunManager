{
  "$schema": "https://raw.githubusercontent.com/dotnet/docfx/main/schemas/docfx.schema.json",
  "metadata": [
    {
      "src": [
        {
          "files": [
            "../src/DeathrunManager/DeathrunManager.csproj",
            "../src/DeathrunManager.Shared/DeathrunManager.Shared.csproj"
          ],
          "src": "../src/"
        }
      ],
      "dest": "api"
    }
  ],
  "build": {
    "content": [
      {
        "files": [
          "**/*.md"
        ]
      }
    ],
    "resource": [
      {
        "files": [
          "images/**"
        ]
      }
    ],
    "output": "_site",
    "template": [
      "default",
      "modern"
    ],
    "globalMetadata": {
      "_appName": "CS2DeathrunManager",
      "_appTitle": "CS2 Deathrun Manager",
      "_enableSearch": true,
      "pdf": false
    }
  }
}
