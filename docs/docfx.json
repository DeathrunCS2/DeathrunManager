{
  "$schema": "https://raw.githubusercontent.com/dotnet/docfx/main/schemas/docfx.schema.json",
  "metadata": {
    "src": [{
      "files": ["**/.sharp/modules/Deathrun.Manager/**.dll"],
      "src": "../src/"
    }],
    "dest": "api"
  },
  "build": {
    "content": [
      {
        "files": [
          "api/*.yml",
          "**/*.{md,yml}"
        ]
      }
    ],
    "resource": [
      {
        "files": [
          "images/**"
        ]
      }
    ],
    "output": "_site",
    "template": [
      "default",
      "modern"
    ],
    "globalMetadata": {
      "_appName": "CS2 DeathrunManager",
      "_appTitle": "CS2 DeathrunManager",
      "_enableSearch": true,
      "pdf": false
    }
  }
}
